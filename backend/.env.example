# .env — Credenciales del sistema (NO subir a GitHub)
# Copiá este archivo como .env y completá con tus datos reales

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=lxs_makers
DB_USER=root
DB_PASSWORD=tu_password_aqui

# Cloudinary
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Seguridad JWT
SECRET_KEY=cambiar_por_una_clave_segura_larga
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
APP_NAME=LXS Makers
DEBUG=True
